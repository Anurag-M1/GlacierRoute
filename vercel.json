{
  "version": 2,
  "buildCommand": "npm run build --prefix apps/web",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/$1"
    }
  ]
}