# GlacierRoute Environment Variables
# Copy this to .env and fill in your values

# ===== AI Providers =====
GROQ_API_KEY=your_groq_api_key
TOGETHER_API_KEY=your_together_api_key
OLLAMA_HOST=http://localhost:11434

# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ===== Redis (Upstash) =====
REDIS_URL=redis://default:token@your-redis.upstash.io:6379
REDIS_TOKEN=your_upstash_redis_token

# ===== Mapbox =====
MAPBOX_PUBLIC_TOKEN=your_mapbox_public_token
MAPBOX_SECRET_TOKEN=your_mapbox_secret_token

# ===== External APIs =====
OPENWEATHER_API_KEY=your_openweathermap_key
RAILWAY_API_KEY=your_railway_api_key
REDBUS_API_KEY=your_redbus_api_key

# ===== Messaging =====
MSG91_API_KEY=your_msg91_key
RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# ===== Search =====
TYPESENSE_API_KEY=your_typesense_key
TYPESENSE_HOST=your_typesense_host

# ===== Storage (Cloudflare R2) =====
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=glacierroute-assets

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token
